# ── Server ────────────────────────────────────────────────────
PORT=3006

# ── CORS Origin ───────────────────────────────────────────────
# For PC only (default):
ALLOWED_ORIGIN=http://localhost:3006

# For mobile testing:
# 1. Find your PC's local IP:
#    Windows: open CMD → type "ipconfig" → look for IPv4 Address (e.g. 192.168.1.5)
#    Mac/Linux: open Terminal → type "ifconfig" → look for inet address
#
# 2. Change ALLOWED_ORIGIN to your PC's IP:
#    ALLOWED_ORIGIN=http://192.168.1.5:3006
#
# 3. Open http://192.168.1.5:3006 on your mobile browser
#    (Make sure phone and PC are on the same WiFi)
#
# 4. For presentation mode (allow all local IPs automatically),
#    the server.js already handles 192.168.x.x and 10.x.x.x ranges